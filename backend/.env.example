# Sécurité
DJANGO_SECRET_KEY=dev-secret-key-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de données
# Option 1: PostgreSQL local (remplacer user, password et dbname)
DATABASE_URL=postgres://user:password@localhost:5432/bachata_db

# Option 2: SQLite (commentez la ligne DATABASE_URL au-dessus pour utiliser SQLite)
# DATABASE_URL=sqlite:///db.sqlite3
